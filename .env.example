# EchoForge Environment Configuration
# Copy this file to .env.local and fill in actual values

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:3001

# Feature Flags
REACT_APP_ENABLE_AUDIO_RECORDING=true
REACT_APP_ENABLE_BACKEND_SYNC=false

# Analytics (optional)
REACT_APP_ANALYTICS_ID=

# Debug Mode
REACT_APP_DEBUG_MODE=false
